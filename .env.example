VITE_APP_NAME=EventHub
VITE_APP_URL=http://localhost:5173

# eventhub_code enables the API-backed email-code sign-in flow.
VITE_AUTH_PROVIDER=eventhub_code

# api persists authenticated workspace changes to the SQLite-backed API.
VITE_PERSISTENCE_PROVIDER=api

VITE_API_BASE_URL=/api
VITE_PAYMENT_API_BASE_URL=/api
VITE_EMAIL_API_BASE_URL=/api

# Values: stripe | mock
VITE_PAYMENT_PROVIDER=mock
VITE_STRIPE_PUBLISHABLE_KEY=

# Values: resend | mock
VITE_EMAIL_PROVIDER=mock
VITE_EMAIL_SENDER=tickets@eventhub.local

# Public checksum salt for demo/offline QR integrity.
VITE_QR_CHECKSUM_SALT=eventhub-demo-salt

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=8787
API_BASE_PATH=/api
APP_URL=http://localhost:5173

# Comma-separated allowed origins for CORS. Blank = allow all localhost in dev.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_PATH=server/data/eventhub.sqlite
BACKUP_DIR=server/data/backups
BACKUP_RETAIN=14

# ─── Auth & Security ──────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QR_CHECKSUM_SALT=eventhub-demo-salt

AUTH_CODE_TTL_MINUTES=10
AUTH_REQUEST_COOLDOWN_SECONDS=60
AUTH_REQUEST_WINDOW_MINUTES=15
AUTH_REQUEST_LIMIT_PER_EMAIL=5
AUTH_REQUEST_LIMIT_PER_IP=20
AUTH_VERIFY_WINDOW_MINUTES=15
AUTH_VERIFY_FAILURE_LIMIT=5
AUTH_LOCKOUT_MINUTES=15
INVITE_TTL_HOURS=72
SESSION_TTL_HOURS=24

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_SENDER=tickets@eventhub.local

# ─── Demo data ────────────────────────────────────────────────────────────────
SEED_DEMO_DATA=true

# ─── Logging ──────────────────────────────────────────────────────────────────
# json | pretty
LOG_FORMAT=pretty
# error | warn | info | debug
LOG_LEVEL=info
# Optional Slack/webhook URL for critical error alerts
# ALERT_WEBHOOK_URL=
