NODE_ENV=production
API_PORT=8787
API_BASE_PATH=/api
APP_URL=https://eventhub.kopaegroup.com
CORS_ORIGINS=https://eventhub.kopaegroup.com
DATABASE_PATH=/var/lib/eventhub/eventhub.sqlite
BACKUP_DIR=/var/lib/eventhub/backups
BACKUP_RETAIN=30

# REQUIRED — generate with: openssl rand -hex 32
QR_CHECKSUM_SALT=replace-me

AUTH_CODE_TTL_MINUTES=10
AUTH_REQUEST_COOLDOWN_SECONDS=60
AUTH_REQUEST_WINDOW_MINUTES=15
AUTH_REQUEST_LIMIT_PER_EMAIL=5
AUTH_REQUEST_LIMIT_PER_IP=20
AUTH_VERIFY_WINDOW_MINUTES=15
AUTH_VERIFY_FAILURE_LIMIT=5
AUTH_LOCKOUT_MINUTES=15
INVITE_TTL_HOURS=72
SESSION_TTL_HOURS=24

# Payment (Stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email (Resend)
RESEND_API_KEY=
EMAIL_SENDER=tickets@kopaegroup.com

LOG_FORMAT=json
LOG_LEVEL=info

# Optional — Slack/Discord webhook for critical alerts
ALERT_WEBHOOK_URL=
