NODE_ENV=staging
API_PORT=8787
API_BASE_PATH=/api
APP_URL=https://staging.eventhub.local
CORS_ORIGINS=https://staging.eventhub.local
DATABASE_PATH=server/data/eventhub-staging.sqlite
BACKUP_DIR=server/data/backups
BACKUP_RETAIN=14
QR_CHECKSUM_SALT=replace-me
AUTH_CODE_TTL_MINUTES=10
AUTH_REQUEST_COOLDOWN_SECONDS=60
AUTH_REQUEST_WINDOW_MINUTES=15
AUTH_REQUEST_LIMIT_PER_EMAIL=5
AUTH_REQUEST_LIMIT_PER_IP=20
AUTH_VERIFY_WINDOW_MINUTES=15
AUTH_VERIFY_FAILURE_LIMIT=5
AUTH_LOCKOUT_MINUTES=15
INVITE_TTL_HOURS=72
SESSION_TTL_HOURS=24
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=
EMAIL_SENDER=tickets@staging.eventhub.local
SEED_DEMO_DATA=false
LOG_FORMAT=json
LOG_LEVEL=info
ALERT_WEBHOOK_URL=
